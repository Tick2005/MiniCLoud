$TTL    604800
@       IN      SOA     ns.cloud.local. admin.cloud.local. (
                      4         ; Serial
                      604800    ; Refresh
                      86400     ; Retry
                      2419200   ; Expire
                      604800 )  ; Negative Cache TTL
;
@       IN      NS      ns.cloud.local.
ns      IN      A       127.0.0.1
web-frontend-server IN A 10.10.10.10
